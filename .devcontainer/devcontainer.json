{
  "name": "Guardian — Ledger Agent Stack",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },

  "onCreateCommand": "sudo apt-get update -qq && sudo apt-get install -y -qq qemu-user-static && pip install --quiet speculos",
  "postCreateCommand": "npm install -g pnpm && pnpm install",

  "forwardPorts": [5000, 9999],
  "portsAttributes": {
    "5000": {
      "label": "Speculos — Device Screen",
      "onAutoForward": "openBrowser"
    },
    "9999": {
      "label": "Speculos — APDU TCP",
      "onAutoForward": "silent"
    }
  }
}
