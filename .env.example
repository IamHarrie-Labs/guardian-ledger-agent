# Copy this to .env and fill in your values
# NEVER commit .env to git

# OpenAI / LLM (for agent reasoning)
OPENAI_API_KEY=your_key_here

# Ethereum Sepolia RPC (use a free Infura/Alchemy endpoint)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Speculos connection (defaults — change only if you moved ports)
SPECULOS_API_URL=http://127.0.0.1:5000
SPECULOS_APDU_PORT=9999

# Treasury policy config
WHITELIST_ADDRESSES=0xYourColdWallet,0xAnotherTrustedAddress
MAX_TX_AMOUNT_ETH=0.5
