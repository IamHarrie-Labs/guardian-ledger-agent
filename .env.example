# Guardian — environment template
# Copy to .env and fill in your values

# Agent mode — set MOCK_AGENT=true to skip OpenAI (uses regex parser)
MOCK_AGENT=true
# OPENAI_API_KEY=sk-...   <- uncomment to use real GPT-4o-mini

# Ethereum Sepolia RPC
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Speculos connection (default ports)
SPECULOS_APDU_PORT=9999
SPECULOS_API_PORT=5000

# Treasury policy
WHITELIST_ADDRESSES=0xYOUR_COLD_WALLET_ADDRESS_HERE
MAX_TX_AMOUNT_ETH=0.5

# Dev mode — signs on device but skips broadcast
# Set to false when running with a funded Sepolia wallet
SKIP_BROADCAST=true
